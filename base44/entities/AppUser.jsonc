{
  "name": "AppUser",
  "type": "object",
  "properties": {
    "username": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "password": {
      "type": "string"
    },
    "avatar_url": {
      "type": "string"
    },
    "bio": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "admin",
        "gamer"
      ],
      "default": "user"
    },
    "audience_group": {
      "type": "string",
      "enum": [
        "girl",
        "boy",
        "mixed"
      ]
    },
    "requested_role": {
      "type": "string",
      "enum": [
        "girl",
        "boy",
        "mixed"
      ]
    },
    "is_donor": {
      "type": "boolean",
      "default": false
    },
    "tokens": {
      "type": "number",
      "default": 100
    },
    "has_seen_tutorial": {
      "type": "boolean",
      "default": false
    },
    "clan_tutorial_seen": {
      "type": "boolean",
      "default": false
    },
    "propass_tutorial_seen": {
      "type": "boolean",
      "default": false
    },
    "last_seen": {
      "type": "string",
      "format": "date-time"
    },
    "frame_style": {
      "type": "string",
      "enum": [
        "none",
        "gold",
        "neon",
        "fire",
        "glitch",
        "rainbow",
        "diamond",
        "cyber",
        "nature",
        "cosmic",
        "lightning",
        "ice",
        "lava",
        "toxic",
        "shadow",
        "celestial",
        "galaxy",
        "blood",
        "ocean",
        "phoenix",
        "dragon",
        "aurora",
        "eternal",
        "void",
        "daily_aurora",
        "daily_cosmos",
        "daily_phoenix",
        "bp_cosmic_rift",
        "bp_dragon_breath",
        "bp_cyber_samurai",
        "bp_god_tier",
        "hub_2_0",
        "legendary",
        "divine",
        "mythic",
        "genesis",
        "void_titan",
        "s2_apocalypse",
        "s2_doomsday",
        "s2_mutant"
      ],
      "default": "none"
    },
    "owned_frames": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "active_badge": {
      "type": "string"
    },
    "owned_badges": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "active_animation": {
      "type": "string",
      "default": "none"
    },
    "owned_animations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "owned_video_frames": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "owned_themes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "default"
      ]
    },
    "active_theme": {
      "type": "string",
      "default": "default"
    },
    "custom_themes": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "active_banner": {
      "type": "string",
      "default": "none"
    },
    "owned_banners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "active_background_animation": {
      "type": "string",
      "default": "default"
    },
    "owned_background_animations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "default"
      ]
    },
    "owned_bundles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "owned_game_upgrades": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "owned_emotes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "pokemon_partner_id": {
      "type": "number"
    },
    "pokemon_partner_sprite": {
      "type": "string"
    },
    "pokemon_partner_name": {
      "type": "string"
    },
