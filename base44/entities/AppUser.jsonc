    "bp_level": {
      "type": "number",
      "default": 1
    },
    "bp_xp": {
      "type": "number",
      "default": 0
    },
    "bp_premium": {
      "type": "boolean",
      "default": false
    },
    "bp_claimed_free": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "default": []
    },
    "bp_claimed_premium": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "default": []
    },
    "bp_claimed_bonus": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "default": []
    },
    "shard_inventory": {
      "type": "object",
      "default": {
        "spark": 0,
        "void": 0,
        "nova": 0,
        "omega": 0
      }
    },
    "bp_shard_claimed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "shard_crafted": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "owned_titles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "active_title": {
      "type": "string"
    },
    "owned_chat_colors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "active_chat_color": {
      "type": "string"
    },
    "owned_profile_effects": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "active_profile_effect": {
      "type": "string"
    },
    "owned_cursor_trails": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "active_cursor_trail": {
      "type": "string",
      "default": "none"
    },
    "owned_profile_sounds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "active_profile_sound": {
      "type": "string",
      "default": "none"
    },
    "test_season_2": {
      "type": "boolean",
      "default": false
    },
    "temp_frame_id": {
      "type": "string"
    },
    "temp_frame_expires": {
      "type": "string",
      "format": "date-time"
    },
    "temp_animation_id": {
      "type": "string"
    },
    "temp_animation_expires": {
      "type": "string",
      "format": "date-time"
    },
    "neon_dash_upgrades": {
      "type": "object",
      "default": {}
    },
    "neon_dash_stats": {
      "type": "object",
      "default": {}
    },
    "neon_racer_data": {
      "type": "object",
      "default": {}
    },
    "pro_pass": {
      "type": "object",
      "default": {}
    },
    "pokemon_story_progress": {
      "type": "object",
      "default": {}
    },
    "reset_token": {
      "type": "string"
    },
    "reset_token_expires": {
      "type": "string",
      "format": "date-time"
    },
    "daily_game_xp_used": {
      "type": "number",
      "default": 0,
      "description": "XP bereits heute aus Spielen verdient (wird t\u00e4glich zur\u00fcckgesetzt)"
    },
    "daily_game_xp_date": {
      "type": "string",
      "description": "Datum (YYYY-MM-DD) des letzten XP-Trackings \u2013 zur t\u00e4glichen Reset-Erkennung"
    },
    "whatsapp_channel_seen": {
      "type": "boolean",
      "default": false,
      "description": "Hat der Nutzer das WhatsApp-Kanal-Popup best\u00e4tigt oder abgelehnt"
    }
  },
  "required": [
    "username",
    "password"
  ]
}