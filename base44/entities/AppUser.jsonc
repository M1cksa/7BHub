      "type": "boolean",
      "default": false
    },
    "newsletter_asked": {
      "type": "boolean",
      "default": false
    },
    "approved": {
      "type": "boolean",
      "default": false
    },
    "agreed_to_terms": {
      "type": "boolean",
      "default": false
    },
    "agreed_terms_version": {
      "type": "string"
    },
    "agreed_to_video_policy": {
      "type": "boolean",
      "default": false
    },
    "terms_agreed_at": {
      "type": "string",
      "format": "date-time"
    },
    "privacy_profile_visible": {
      "type": "boolean",
      "default": true
    },
    "privacy_show_email": {
      "type": "boolean",
      "default": false
    },
    "privacy_allow_messages": {
      "type": "boolean",
      "default": true
    },
    "notify_new_follower": {
      "type": "boolean",
      "default": true
    },
    "notify_new_comment": {
      "type": "boolean",
      "default": true
    },
    "notify_new_like": {
      "type": "boolean",
      "default": true
    },
    "banned": {
      "type": "boolean",
      "default": false
    },
    "ban_reason": {
      "type": "string"
    },
    "trial_completed": {
      "type": "boolean",
      "default": false
    },
    "daily_login_streak": {
      "type": "number",
      "default": 0
    },
    "daily_login_last_claim": {
      "type": "string",
      "format": "date-time"
    },
    "daily_login_cycle_start": {
      "type": "string",
      "format": "date-time"
    },
    "daily_login_claimed_days": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "default": []
    },
    "welcome_reward_claimed": {
      "type": "boolean",
      "default": false
    },
    "v2_quest_claimed": {
      "type": "boolean",
      "default": false
    },
    "v2_quest_dismissed": {
      "type": "boolean",
      "default": false
